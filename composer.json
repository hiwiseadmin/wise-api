{
    "name": "wiseadmin/wise-api",
    "description": "WiseAdmin API 快速开发工具包 — 提供限流、签名验证、JWT 鉴权、统一响应格式、调试面板与 API 日志记录能力",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "wiseadmin",
        "thinkphp",
        "api",
        "rate-limit",
        "jwt",
        "sign",
        "api-log"
    ],
    "authors": [
        {
            "name": "WiseAdmin Team",
            "email": "wiseadmin@126.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.0 || ^8.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "wiseadmin/wise-jwt": "@dev",
        "ext-json": "*"
    },
    "suggest": {
        "topthink/think-queue": "^2.0 || ^3.0",
        "topthink/think-migration": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": ">=9.0",
        "mockery/mockery": ">=1.0",
        "symfony/var-dumper": "^5.0 || ^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "wise\\api\\": "src/"
        },
        "files": [
            "src/helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "wise\\api\\test\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "extra": {
        "think": {
            "services": [
                "wise\\api\\Service"
            ],
            "config": {
                "wise-api": "config/wise-api.php"
            },
            "migrate-path": "database/migrations"
        }
    },
    "homepage": "https://github.com/hiwiseadmin/wise-api",
    "archive": {
        "exclude": [
            "/tests",
            "/docs",
            "/.github",
            "/phpunit.xml",
            "/.gitattributes",
            "/.gitignore",
            "/*.md",
            "!/README.md",
            "/qa/"
        ]
    }
}
