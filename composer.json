{
    "name": "wiseadmin/wise-api",
    "description": "WiseAdmin API Toolkit - 为 ThinkPHP 提供的 API 快速开发工具包（限流/签名/JWT/统一响应/调试面板/API日志）",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "wiseadmin",
        "thinkphp",
        "api",
        "rate-limit",
        "jwt",
        "sign",
        "api-log"
    ],
    "authors": [
        {
            "name": "WiseAdmin",
            "email": "wiseadmin@126.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.0 || ^8.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "wiseadmin/wise-jwt": "@dev",
        "ext-json": "*"
    },
    "suggest": {
        "topthink/think-queue": "^2.0 || ^3.0",
        "topthink/think-migration": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": ">=9.0",
        "mockery/mockery": ">=1.0",
        "symfony/var-dumper": "^5.0 || ^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "wise\\api\\": "src/"
        },
        "files": [
            "src/helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "wise\\api\\test\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "extra": {
        "think": {
            "services": [
                "wise\\api\\Service"
            ],
            "config": {
                "wise-api": "config/wise-api.php"
            },
            "migrate-path": "database/migrations"
        }
    }
}
